{
  "compilerOptions": {
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": "."
  },
  "include": ["src/**/*", "vite.config.js", "postcss.config.js", "tailwind.config.js"]
}
